# Frontend
VITE_API_URL=http://localhost:4000/api

# Backend
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp checkout
# Use country code, only numbers. Example Colombia: 573001234567
WHATSAPP_PHONE_NUMBER=573001234567
WHATSAPP_DEFAULT_MESSAGE_PREFIX=Hola, quiero hacer este pedido en Della:

# Optional: create pending orders before redirecting to WhatsApp
CREATE_PENDING_WHATSAPP_ORDERS=true

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=2h
